{
  "manifest_version": 3,
  "name": "TeraLead - Business Data Scraper",
  "version": "1.0.0",
  "description": "Extract business data from Google Maps and enrich with email addresses",
  "permissions": [
    "storage",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.google.com/*",
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/content.ts-loader-D4pEMvsA.js"
      ],
      "matches": [
        "https://www.google.com/maps/*"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "TeraLead Business Scraper"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "https://www.google.com/*"
      ],
      "resources": [
        "assets/shared-DjaeoqTz.js",
        "assets/content.ts-BnNBG5_N.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
